{
  "name": "pronto-cli",
  "version": "0.1.0",
  "description": "Ship in any language, for any platform. The localization CLI that works for React AND WordPress.",
  "main": "dist/index.js",
  "bin": {
    "pronto": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "i18n",
    "localization",
    "translation",
    "cli",
    "react",
    "nextjs",
    "wordpress",
    "webflow"
  ],
  "author": "Pronto",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.1",
    "ini": "^4.1.3",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
